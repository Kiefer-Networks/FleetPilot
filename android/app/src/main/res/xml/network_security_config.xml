<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Disallow cleartext (HTTP) traffic for all domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Certificate pinning for Iru/Kandji US API -->
    <domain-config>
        <domain includeSubdomains="true">api.kandji.io</domain>
        <pin-set expiration="2027-06-01">
            <!-- Let's Encrypt R13 intermediate (current US issuer) -->
            <pin digest="SHA-256">AlSQhgtJirc8ahLyekmtX+Iw+v46yPYRLJt9Cq1GlB0=</pin>
            <!-- Let's Encrypt R12 intermediate (alternate issuer) -->
            <pin digest="SHA-256">kZwN96eHtZftBWrOZUsd6cA4es80n3NzSk/XtYz2EqQ=</pin>
            <!-- ISRG Root X1 (backup — valid until 2035) -->
            <pin digest="SHA-256">C5+lpZ7tcVwmwQIMcRtPbsQtWLABXhQzejna0wHFr8M=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Certificate pinning for Iru/Kandji EU API -->
    <domain-config>
        <domain includeSubdomains="true">api.eu.kandji.io</domain>
        <pin-set expiration="2027-06-01">
            <!-- Let's Encrypt R12 intermediate (current EU issuer) -->
            <pin digest="SHA-256">kZwN96eHtZftBWrOZUsd6cA4es80n3NzSk/XtYz2EqQ=</pin>
            <!-- Let's Encrypt R13 intermediate (alternate issuer) -->
            <pin digest="SHA-256">AlSQhgtJirc8ahLyekmtX+Iw+v46yPYRLJt9Cq1GlB0=</pin>
            <!-- ISRG Root X1 (backup — valid until 2035) -->
            <pin digest="SHA-256">C5+lpZ7tcVwmwQIMcRtPbsQtWLABXhQzejna0wHFr8M=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
